/*@
  predicate StackPush{S,T}(Stack* s, value_type v, Stack* t) =
    StackTop{T}(t)      == v                    &&
    StackCapacity{S}(s) == StackCapacity{T}(t)  &&
    StackSize{S}(s) + 1 == StackSize{T}(t)      &&
    StackPrefix{S,T}(s, t);
*/

