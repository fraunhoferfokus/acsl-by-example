      \let start = IndexOfNotEqual(a, n, v, k-1) + 1;
      // Negative rank: invalid request
      k < 0 ? -1 :
        // Now we know 0 <= k
        (n <= 0 ? 0 :
          // Now we know 0 < n
          k < count ? start + FindNotEqual(a, start, n, v) : n
