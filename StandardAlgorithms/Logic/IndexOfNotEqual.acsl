        0 <= k < CountNotEqual(a, n, v)  ==>
        IndexOfNotEqual(a, n, v, k) == IndexOfNotEqual(a, n+1, v, k);

    lemma IndexOfNotEqual_Unchanged{K,L}:
      \forall value_type *a, v, integer n, k;
        Unchanged{K,L}(a, n)  ==>
        IndexOfNotEqual{K}(a, n, v, k) == IndexOfNotEqual{L}(a, n, v, k);
  }  
