        IndexOfNotEqual(a, n, v, k-1) < IndexOfNotEqual(a, n, v, k);

    lemma IndexOfNotEqual_Segment:
      \forall value_type *a, v, integer n, k;
        0 < n                            ==>
        0 <= k                           ==>
